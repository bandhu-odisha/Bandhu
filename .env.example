# Copy this file to .env and fill in real values. Never commit .env.

# Django
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=['localhost', '127.0.0.1', 'bandhuodisha.in', 'www.bandhuodisha.in']

# Database — use sqlite for a quick local start, or mysql to match production
DB_ENGINE=sqlite
# DB_ENGINE=mysql
# DB_HOST=localhost
# DB_NAME=bandhu_db
# DB_USER=bandhu_root
# DB_PASS=your-password
# DB_PORT=3306

# Email (optional for local dev; required in production)
ADMINS_EMAIL=['bandhuodisha@gmail.com']
EMAIL_HOST=your-smtp-host
EMAIL_HOST_USER=no-reply@bandhuodisha.in
EMAIL_HOST_PASSWORD=your-email-password
EMAIL_PORT=465
EMAIL_USE_SSL=True
EMAIL_USE_TLS=False
SENDER_EMAIL=Bandhu

# SendGrid (optional)
SENDGRID_API_KEY=your-sendgrid-key

# Social auth (optional for local dev)
SOCIAL_AUTH_FACEBOOK_KEY=
SOCIAL_AUTH_FACEBOOK_SECRET=
SOCIAL_AUTH_GOOGLE_OAUTH2_KEY=
SOCIAL_AUTH_GOOGLE_OAUTH2_SECRET=

# Static & media — use absolute paths on your machine
STATIC_ROOT=/absolute/path/to/Bandhu/staticfiles
STATIC_URL=/static/
MEDIA_ROOT=/absolute/path/to/Bandhu/media
MEDIA_URL=/media/
